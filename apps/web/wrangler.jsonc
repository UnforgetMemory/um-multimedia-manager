{
  "name": "umm-web",
  "pages_build_output_dir": "dist",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "umm",
      "database_id": "local-dev"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV_SESSION",
      "id": "local-dev"
    }
  ]
}