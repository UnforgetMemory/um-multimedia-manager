{
  "name": "um-multimedia-manager",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/*"
  ],
  "scripts": {
    "dev:extension": "npm run dev -w apps/extension",
    "dev:web": "npm run dev -w apps/web",
    "build:extension": "npm run build -w apps/extension",
    "build:web": "npm run build -w apps/web",
    "type-check": "npm run type-check -w apps/extension && npm run type-check -w apps/web",
    "deploy:web": "npm run deploy -w apps/web",
    "db:generate": "npm run generate -w infra/drizzle",
    "db:migrate": "npm run migrate -w infra/drizzle",
    "clean": "npm run clean -w apps/extension",
    "deps:check": "npm outdated",
    "deps:audit": "npm audit"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "drizzle-kit": "^0.30.6",
    "drizzle-orm": "^0.42.0"
  }
}
